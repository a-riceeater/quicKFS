{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quicKFS",
  "version": "0.1.0",
  "identifier": "org.quickfs.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "quicKFS",
        "width": 1080,
        "height": 720,
        "minWidth": 760,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#242321",
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "shortDescription": "A secure quicKFS client for macOS",
    "longDescription": "Pair with and browse read-only quicKFS servers over QUIC.",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
